# Copy this file to .env before starting the project.
APP_NAME=DigitalCard API
APP_ENV=development
SECRET_KEY=change-this-development-key-before-use-1234567890
DATABASE_URL=sqlite:///./data/digitalcard.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
VITE_API_BASE_URL=http://localhost:8000/api/v1
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
